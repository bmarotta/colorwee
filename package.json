{
  "name": "colorwee",
  "version": "1.0.7",
  "description": "A mini package for color conversion not bloated with functions you will never use",
  "main": "./dist/color.js",
  "types": "./dist/color.d.ts",
  "module": "./dist/color.es.js",
  "exports": {
    "import": "./dist/color.es.js",
    "require": "./dist/color.js"
  },
  "scripts": {
    "clean": "rimraf dist",
    "test": "jest --config jest.config.js --collect-coverage",
    "test-watch": "jest --config jest.config.js --collect-coverage --watch",
    "build": "npm run clean && rollup -c rollup.config.js --bundleConfigAsCjs",
    "watch": "rollup -w -c rollup.config.js --bundleConfigAsCjs",
    "watch:es": "rollup -w -c rollup.config.es.js --bundleConfigAsCjs",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "npm run format && eslint . --ext .ts --fix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-junit": "^16.0.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "rollup": "^4.59.0",
    "rollup-plugin-cleanup": "^3.2.1",
    "ts-jest": "^29.4.6",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "keywords": [
    "color",
    "colour",
    "css",
    "conversion",
    "convert",
    "converter",
    "manipulation",
    "rgb",
    "rgba",
    "hsl",
    "hsla",
    "hex",
    "alpha",
    "red",
    "green",
    "blue",
    "hue",
    "saturation",
    "lightness",
    "color-distance",
    "color-conversion"
  ],
  "author": "Bruno Marotta",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bmarotta/colorwee.git"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false
}
